{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Personal Assistant Agent",
  "version": "0.1.0",
  "identifier": "com.personal-assistant.agent",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build && npm run build:sidecar"
  },
  "app": {
    "windows": [
      {
        "title": "个人助理 Agent",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' ws://127.0.0.1:* http://127.0.0.1:*"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "externalBin": ["binaries/agent-api"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "shell": {
      "open": true
    },
    "updater": {
      "active": false,
      "dialog": true,
      "endpoints": [
        "https://github.com/YOUR_ORG/my-agent-rs/releases/latest/download/latest.json"
      ],
      "pubkey": "REPLACE_WITH_TAURI_SIGNER_PUBLIC_KEY"
    }
  }
}
